from sentence_transformers import SentenceTransformer
import faiss
import numpy as np
import os

# ==========================================

# EMBEDDING MODEL

# ==========================================

model = SentenceTransformer(
"all-MiniLM-L6-v2"
)

documents = []
sources = []

# ==========================================

# TEXT CHUNKING

# ==========================================

def chunk_text(
text,
chunk_size=500
):

```
chunks = []

for i in range(
    0,
    len(text),
    chunk_size
):

    chunks.append(
        text[i:i + chunk_size]
    )

return chunks
```

# ==========================================

# LOAD KNOWLEDGE FILES

# ==========================================

def load_documents():

```
global documents
global sources

documents.clear()
sources.clear()

knowledge_path = "knowledge"

for root, dirs, files in os.walk(
    knowledge_path
):

    for file in files:

        if file.endswith(".md"):

            file_path = os.path.join(
                root,
                file
            )

            try:

                with open(
                    file_path,
                    "r",
                    encoding="utf-8"
                ) as f:

                    content = f.read()

                chunks = chunk_text(
                    content
                )

                for chunk in chunks:

                    documents.append(
                        chunk
                    )

                    sources.append(
                        file_path
                    )

            except Exception as e:

                print(
                    f"Error reading {file_path}: {e}"
                )
```

# ==========================================

# BUILD FAISS INDEX

# ==========================================

def build_index():

```
load_documents()

if len(documents) == 0:

    raise Exception(
        "No knowledge documents found."
    )

embeddings = model.encode(
    documents,
    convert_to_numpy=True
)

embeddings = embeddings.astype(
    "float32"
)

dimension = embeddings.shape[1]

index = faiss.IndexFlatL2(
    dimension
)

index.add(
    embeddings
)

return index
```

# ==========================================

# INITIALIZE INDEX

# ==========================================

index = build_index()

# ==========================================

# SEARCH KNOWLEDGE BASE

# ==========================================

def search_knowledge(
query,
top_k=3
):

```
try:

    query_embedding = model.encode(
        [query],
        convert_to_numpy=True
    )

    query_embedding = query_embedding.astype(
        "float32"
    )

    distances, indices = index.search(
        query_embedding,
        top_k
    )

    results = []

    for rank, idx in enumerate(
        indices[0]
    ):

        if idx < len(documents):

            results.append(
                f"""
```

Source:
{sources[idx]}

Rank:
{rank + 1}

Content:
{documents[idx]}
"""
)

```
    return "\n\n".join(
        results
    )

except Exception as e:

    print(
        f"RAG Search Error: {e}"
    )

    return ""
```

# ==========================================

# TEST

# ==========================================

if **name** == "**main**":

```
query = "Disk usage is 100%"

results = search_knowledge(
    query=query,
    top_k=3
)

print(results)


